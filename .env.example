# yt-automation backend environment
API_TOKEN=change-me-in-production
OPENROUTER_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=tencent/hy3:free
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=yt-automation/0.1
CORS_ORIGIN=https://yt-automation.freedev.app
DATABASE_URL=sqlite:///./ytauto.db

# Pipeline ReyPirataChaman (ver PROGRESS.md)
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-flash-latest
YOUTUBE_API_KEY=REPLACE_WITH_YOUR_YOUTUBE_DATA_API_KEY
TELEGRAM_BOT_TOKEN_RPC=REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID_RPC=REPLACE_WITH_FRANCO_CHAT_ID
NICHE_KEYWORDS=conciencia,viaje interior,meditación,desarrollo personal
BACKLOG_MIN_PENDING=3

# Broll de fondo (render_worker, bare host - ver broll_gif.py). Gratis, sin
